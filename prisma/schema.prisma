generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id              String    @id @default(cuid())
  level           String
  /** N4 등 파일 순서 유지용. null이면 id 기반 안정 랜덤 정렬 */
  sortIndex       Int?
  kanji           String?
  reading         String
  meaning         String
  example         String
  exampleReading  String?
  exampleMeaning  String?
  userWord        UserWord?
}

model UserWord {
  id           String   @id @default(cuid())
  wordId       String   @unique
  word         Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wrongCount   Int      @default(0)
  /** 객관식·세트 시험 등 정답 처리 누적 */
  correctCount Int      @default(0)
  isExcluded   Boolean  @default(false)
  /** 단어 공부 화면에서 연 단어만 메인 시험 풀에 포함 */
  seenInStudy  Boolean  @default(false)
  lastSeenAt   DateTime @default(now())
}

/** 출석 체크(로컬 날짜 문자열 YYYY-MM-DD). 단일 사용자 앱 기준 */
model AttendanceDay {
  day       String   @id
  createdAt DateTime @default(now())
}
